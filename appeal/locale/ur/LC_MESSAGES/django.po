" \n"
"            Feed (%(appeals_length)s)\n"
msgstr ""
" \n"
"            فیڈ (%(appeals_length)s)\n"

#: appeal/templates/appeal/appeals.html:41
msgid "Filter"
msgstr "فلٹر"

#: appeal/templates/appeal/appeals.html:46
msgid "Participating"
msgstr "شرکت کر رہے ہیں"

#: appeal/templates/appeal/appeals.html:85
msgid "Get involved by accepting an Invitation, or sending a new one."
msgstr "دعوت قبول کر کے یا نئی دعوت بھیج کر شامل ہوں۔"

#: appeal/templates/appeal/appeals.html:91
msgid "All"
msgstr "سب"

#: appeal/templates/appeal/appeals.html:95
msgid "filtered"
msgstr "فلٹر شدہ"

#: appeal/templates/appeal/appeals.html:132
msgid "Unfortunately no Invitations match your Filters."
msgstr "بدقسمتی سے کوئی دعوت آپ کے فلٹرز سے مطابقت نہیں رکھتی۔"

#: appeal/templates/appeal/appeals.html:135
msgid "Try deactivating a Filter or send out your own Invitation."
msgstr "کسی فلٹر کو غیر فعال کریں یا اپنی دعوت بھیجیں۔"

#: appeal/templates/appeal/appeals.html:150
#, python-format
msgid ""
"\n"
"                Open an Invitation %(br)s or send a new one!\n"
"    "
msgstr ""
"\n"
"                ایک دعوت کھولیں %(br)s یا نئی بھیجیں!\n"
"    "

#: appeal/templates/appeal/bid.html:76
msgid "Cancel this Offer?"
msgstr "کیا آپ اس پیشکش کو منسوخ کرنا چاہتے ہیں؟"

#: appeal/templates/appeal/keen.html:69
msgid "Keen To Play? Send Invitation?"
msgstr "کھیلنے کے خواہشمند ہیں؟ دعوت بھیجیں؟"
