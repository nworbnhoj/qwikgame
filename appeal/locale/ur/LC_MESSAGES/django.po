#: appeal/forms.py:57 appeal/forms.py:115 appeal/forms.py:124
msgid "When are you keen to play?"
msgstr "آپ کب کھیلنے کے خواہشمند ہیں؟"

#: appeal/forms.py:58
msgid "WHAT TIME WORKS FOR YOU?"
msgstr "آپ کے لیے کون سا وقت موزوں ہے؟"

#: appeal/forms.py:109
msgid "GAME"
msgstr "کھیل"

#: appeal/forms.py:118
msgid "TODAY"
msgstr "آج"

#: appeal/forms.py:127
msgid "TOMORROW"
msgstr "کل"

#: appeal/forms.py:135
msgid "FRIENDS"
msgstr "دوست"

#: appeal/forms.py:213
msgid "Please select at least one hour in today or tomorrow."
msgstr "براہ کرم آج یا کل میں کم از کم ایک گھنٹہ منتخب کریں۔"

#: appeal/forms.py:220 appeal/forms.py:236
msgid "Sorry, that Venue selection did not work. Please try again."
msgstr "معذرت، مقام کا انتخاب کامیاب نہیں ہوا۔ براہ کرم دوبارہ کوشش کریں۔"

#: appeal/forms.py:226
msgid "Please invite at least one Friend."
msgstr "براہ کرم کم از کم ایک دوست کو مدعو کریں۔"

#: appeal/forms.py:241 appeal/templates/appeal/keen.html:88
msgid "Invite Friends Only"
msgstr "صرف دوستوں کو مدعو کریں"

#: appeal/forms.py:243
msgid ""
"You don't have any added friends yet. Please add them from the Friends tab"
msgstr ""
"آپ نے ابھی تک کوئی دوست شامل نہیں کیے۔ براہ کرم فرینڈز ٹیب سے انہیں شامل کریں"

#: appeal/forms.py:247
msgid "Select from map"
msgstr "نقشے سے منتخب کریں"

#: appeal/forms.py:251
msgid "VENUE"
msgstr "مقام"

#: appeal/models.py:173
#, python-format
msgid "Proposed %(game)s at %(venue)s, %(date)s, %(time)s"
msgstr "%(venue)s میں %(date)s، %(time)s پر %(game)s کی تجویز"

#: appeal/models.py:180
#, python-format
msgid " with %(fiends)s"
msgstr " %(fiends)s کے ساتھ"

#: appeal/models.py:184
#, fuzzy
#| msgid "Cancel this Invitation?"
msgid "Cancelled Invitation"
msgstr "کیا آپ اس دعوت کو منسوخ کرنا چاہتے ہیں؟"

#: appeal/models.py:189
#, python-format
msgid "This is the first QWIKGAME of %(game)s at this Venue."
msgstr "یہ اس مقام پر %(game)s کا پہلا QWIKGAME ہے۔"

#: appeal/models.py:190
msgid "Please check that the Venue has everything you need for the Match."
msgstr ""
"براہِ کرم تصدیق کریں کہ اس مقام پر میچ کے لیے تمام ضروری سہولیات موجود ہیں۔"

#: appeal/models.py:192
#, python-format
msgid "Updated hours: %(hours)s"
msgstr "اپ ڈیٹ شدہ اوقات: %(hours)s"

#: appeal/models.py:331
#, python-format
msgid "Confirmed for %(hours)s with %(name)s"
msgstr "%(name)s کے ساتھ %(hours)s کے لیے تصدیق ہو گئی"

#: appeal/models.py:343
#, python-format
msgid "Offered %(hours)s"
msgstr "%(hours)s کی پیشکش کی"

#: appeal/models.py:354
#, python-format
msgid "Declined %(hours)s with %(name)s"
msgstr "%(name)s کے ساتھ %(hours)s مسترد کر دیا گیا"

#: appeal/models.py:366
msgid "bid expired"
msgstr "پیشکش کی مدت ختم ہو گئی"

#: appeal/models.py:375
#, python-format
msgid "withdrew %(hours)s"
msgstr "%(hours)s واپس لے لیا"

#: appeal/templates/appeal/accept.html:53
msgid "Cancel this Invitation?"
msgstr "کیا آپ اس دعوت کو منسوخ کرنا چاہتے ہیں؟"

#: appeal/templates/appeal/accept.html:55 appeal/templates/appeal/bid.html:78
msgid "cancel"
msgstr "منسوخ کریں"

#: appeal/templates/appeal/accept.html:84
msgid "decline"
msgstr "انکار کریں"

#: appeal/templates/appeal/accept.html:125
msgid ""
"You are about to schedule a Match. A chat session will be opened with your "
"rival. Continue?"
msgstr ""
"آپ ایک میچ طے کرنے والے ہیں۔ آپ کے حریف کے ساتھ چیٹ سیشن کھول دیا جائے گا۔ "
"کیا جاری رکھنا چاہتے ہیں؟"

#: appeal/templates/appeal/appeals.html:7
msgid "Feed"
msgstr "فیڈ"

#: appeal/templates/appeal/appeals.html:24
#: appeal/templates/appeal/appeals.html:156
#: appeal/templates/appeal/keen.html:48 appeal/templates/appeal/keen.html:85
msgid "Invite"
msgstr "دعوت دیں"

